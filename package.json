{
  "name": "@flun/mailer",
  "version": "2.1.10",
  "description": "A powerful and flexible email sending library for Node.js with multiple transport support (SMTP, SMTP Pool, Sendmail, Stream, JSON, SES)",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "mailer-init": "copy-files.js",
    "mailer": "index.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib/",
    "copy-files.js",
    "Mail.js",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mail",
    "email",
    "flun",
    "smtp",
    "sendmail",
    "ses",
    "aws",
    "transport",
    "smtp-pool",
    "email-sender",
    "mailer"
  ],
  "author": "flun <cn@flun.top>",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flunGit/mailer.git"
  },
  "homepage": "https://www.npmjs.com/package/@flun/mailer#readme",
  "bugs": {
    "url": "https://github.com/flunGit/mailer/issues"
  },
  "license": "ISC",
  "engines": {
    "node": ">=22.12.0",
